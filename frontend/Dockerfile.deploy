# Étape 1 : Build de l'application React/Vite
FROM node:22-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

# Étape 2 : Caddy pour servir les fichiers et servir de reverse proxy
FROM caddy:2-alpine

# Copier la configuration Caddy
COPY Caddyfile /etc/caddy/Caddyfile

# Copier les fichiers compilés depuis l'étape 1
COPY --from=builder /app/dist /srv/public

EXPOSE 80 443
